{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../shared/tsconfig.web.jsonc",
	"compilerOptions": {
		// Checking
		"allowSyntheticDefaultImports": true,

		// Output
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"inlineSources": true,
		"removeComments": false,
		"noEmitOnError": false,
		"noEmit": false,
		"composite": true,
		"outDir": "./built/",
		"rootDir": "src",
		"tsBuildInfoFile": "built/tsconfig.game.json"
	},
	"include": [
		"./src/**/*.ts"
	]
}
