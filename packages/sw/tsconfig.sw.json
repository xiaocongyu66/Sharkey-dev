{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../shared/tsconfig.webworker.jsonc",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"removeComments": false,
		"rootDir": ".",
		"outDir": "../../built/_sw_dist_",
		"paths": {
			"@/*": ["./src/*"],
		},
		"typeRoots": [
			"./node_modules/@types",
			"./src/@types"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
